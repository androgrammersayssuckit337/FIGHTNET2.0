rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definitions
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { 
      return id is string && id.size() > 0 && id.size() <= 128; 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }

    // Validation Blueprint for UserPublic
    function isValidUserPublic(data) {
      return data.keys().hasAll(['displayName', 'role']) &&
             data.displayName is string && data.displayName.size() >= 1 && data.displayName.size() <= 100 &&
             data.role in ['fighter', 'fan', 'sponsor'] &&
             (data.get('profileImageUrl', '') is string && data.get('profileImageUrl', '').size() <= 2048) &&
             (data.get('coverImageUrl', '') is string && data.get('coverImageUrl', '').size() <= 2048) &&
             (data.get('bio', '') is string && data.get('bio', '').size() <= 4000) &&
             (data.get('record', '') is string && data.get('record', '').size() <= 50) &&
             (data.get('gym', '') is string && data.get('gym', '').size() <= 200) &&
             (data.get('weightClass', '') is string && data.get('weightClass', '').size() <= 100) &&
             (data.get('hometown', '') is string && data.get('hometown', '').size() <= 100) &&
             (data.get('theme', 'dark') in ['dark', 'light', 'cyberpunk']) &&
             (data.get('isPro', false) is bool);
    }
    // Validation for nested socialLinks (Map)
    function isValidSocialLinks(links) {
      return links is map &&
             (links.get('instagram', '') is string && links.get('instagram', '').size() <= 100) &&
             (links.get('twitter', '') is string && links.get('twitter', '').size() <= 100) &&
             (links.get('youtube', '') is string && links.get('youtube', '').size() <= 100);
    }

    // Validation Blueprint for UserPrivate
    function isValidUserPrivate(data) {
      return data.keys().hasAll(['email', 'updatedAt']) &&
             data.keys().size() == 2 &&
             data.email is string && data.email.size() <= 128 &&
             (data.updatedAt is timestamp || data.updatedAt == request.time);
    }

    // Validation Blueprint for Post
    function isValidPost(data) {
      return data.keys().hasAll(['authorId', 'content', 'createdAt', 'likesCount', 'status']) &&
             data.keys().size() >= 5 && data.keys().size() <= 8 &&
             data.authorId is string && data.authorId == request.auth.uid &&
             data.content is string && data.content.size() >= 1 && data.content.size() <= 4000 &&
             (data.createdAt is timestamp || data.createdAt == request.time) &&
             data.likesCount is number &&
             data.status == 'published' &&
             (data.get('mediaUrl', '') is string && data.get('mediaUrl', '').size() <= 1024) &&
             (data.get('mediaType', '') in ['', 'video', 'image']);
    }

    // Validation Blueprint for Sponsorship Application
    function isValidSponsorship(data) {
      return data.keys().hasAll(['fighterId', 'status', 'pitch', 'createdAt']) &&
             data.keys().size() == 4 &&
             data.fighterId is string && data.fighterId == request.auth.uid &&
             data.status in ['pending', 'approved', 'rejected', 'cancelled'] &&
             data.pitch is string && data.pitch.size() >= 10 && data.pitch.size() <= 5000 &&
             (data.createdAt is timestamp || data.createdAt == request.time);
    }

    // Phase 4: Match Blocks

    match /users/{userId} {
      allow get: if isSignedIn() && isValidId(userId);
      allow list: if isSignedIn();
      
      allow create: if isOwner(userId) && isValidId(userId) && isValidUserPublic(incoming()) && (
        !incoming().keys().hasAll(['socialLinks']) || isValidSocialLinks(incoming().socialLinks)
      );
      
      allow update: if isOwner(userId) && isValidUserPublic(incoming()) && (
        !incoming().keys().hasAll(['socialLinks']) || isValidSocialLinks(incoming().socialLinks)
      ) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'profileImageUrl', 'coverImageUrl', 'bio', 'record', 'gym', 'weightClass', 'hometown', 'socialLinks', 'isPro', 'theme'])
      );

      match /private/info {
        allow get: if isOwner(userId);
        allow write: if isOwner(userId) && isValidUserPrivate(incoming());
      }
    }

    match /posts/{postId} {
      allow get: if isSignedIn() && isValidId(postId);
      allow list: if isSignedIn();
      
      allow create: if isSignedIn() && isValidId(postId) && isValidPost(incoming()) && 
                    incoming().createdAt == request.time &&
                    incoming().likesCount == 0;
      
      allow update: if isSignedIn() && (
        // Action: Edit Post
        (isOwner(existing().authorId) && isValidPost(incoming()) &&
         incoming().diff(existing()).affectedKeys().hasOnly(['content', 'mediaUrl', 'mediaType', 'status']) &&
         incoming().likesCount == existing().likesCount &&
         incoming().authorId == existing().authorId) ||
        // Action: Like Post (Atomic Increment)
        (incoming().diff(existing()).affectedKeys().hasOnly(['likesCount']) &&
         incoming().likesCount == existing().likesCount + 1 &&
         incoming().content == existing().content &&
         incoming().authorId == existing().authorId &&
         incoming().status == existing().status)
      );

      allow delete: if isOwner(existing().authorId);
      
      match /comments/{commentId} {
        allow get, list: if isSignedIn();
        allow create: if isSignedIn() && isValidId(commentId) && isValidComment(incoming());
        allow update, delete: if isOwner(existing().authorId);
      }
    }

    match /sponsorships/{appId} {
      allow get: if isSignedIn() && isValidId(appId) && (
        isOwner(existing().fighterId) || existing().status == 'pending'
      );
      allow list: if isSignedIn() && (
        resource.data.fighterId == request.auth.uid || resource.data.status == 'pending'
      );
      
      allow create: if isSignedIn() && isValidId(appId) && isValidSponsorship(incoming()) && 
                    incoming().createdAt == request.time &&
                    incoming().status == 'pending';
      
      allow update: if isSignedIn() && (
        // Action: Cancel/Edit (Fighter)
        (isOwner(existing().fighterId) && existing().status == 'pending' &&
         isValidSponsorship(incoming()) &&
         incoming().diff(existing()).affectedKeys().hasOnly(['pitch', 'status']) &&
         incoming().status in ['pending', 'cancelled'] &&
         incoming().fighterId == existing().fighterId)
      );
      
      allow delete: if isOwner(existing().fighterId) && existing().status == 'pending';
    }

    // Helper for chat participants
    function isParticipant(participants) {
      return isSignedIn() && (request.auth.uid in participants);
    }

    function isValidChatRoom(data) {
      return data.keys().hasAll(['participantIds', 'updatedAt']) &&
             data.participantIds is list &&
             data.participantIds.size() >= 2 &&
             (data.updatedAt is timestamp || data.updatedAt == request.time);
    }

    function isValidChatMessage(data) {
      return data.keys().hasAll(['senderId', 'content', 'createdAt']) &&
             data.senderId == request.auth.uid &&
             data.content is string && data.content.size() >= 1 && data.content.size() <= 2000 &&
             (data.createdAt is timestamp || data.createdAt == request.time);
    }

    function isValidFightSchedule(data) {
      return data.keys().hasAll(['event', 'location', 'date', 'time', 'status', 'createdAt']) &&
             data.event is string && data.event.size() >= 1 && data.event.size() <= 200 &&
             data.location is string && data.location.size() >= 1 && data.location.size() <= 200 &&
             data.date is string && data.date.size() >= 1 && data.date.size() <= 10 &&
             data.time is string && data.time.size() >= 1 && data.time.size() <= 50 &&
             data.status in ['upcoming', 'live', 'finished'] &&
             (data.createdAt is timestamp || data.createdAt == request.time);
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['ownerId', 'name', 'price', 'stock', 'createdAt']) &&
             data.ownerId == request.auth.uid &&
             data.name is string && data.name.size() >= 1 && data.name.size() <= 200 &&
             data.price is number && data.price >= 0 &&
             data.stock is number && data.stock >= 0 &&
             (data.get('description', '') is string && data.get('description', '').size() <= 2000) &&
             (data.get('imageUrl', '') is string && data.get('imageUrl', '').size() <= 2048) &&
             (data.get('tag', '') is string && data.get('tag', '').size() <= 50) &&
             (data.createdAt is timestamp || data.createdAt == request.time);
    }

    function isValidComment(data) {
      return data.keys().hasAll(['authorId', 'content', 'createdAt']) &&
             data.authorId == request.auth.uid &&
             data.content is string && data.content.size() >= 1 && data.content.size() <= 2000 &&
             (data.createdAt is timestamp || data.createdAt == request.time) &&
             (data.get('authorName', '') is string && data.get('authorName', '').size() <= 100) &&
             (data.get('authorImage', '') is string && data.get('authorImage', '').size() <= 2048);
    }

    match /products/{productId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(productId) && isValidProduct(incoming());
      allow update: if isOwner(existing().ownerId) && isValidProduct(incoming()) &&
                    incoming().ownerId == existing().ownerId;
      allow delete: if isOwner(existing().ownerId);
    }

    match /schedules/{fightId} {
      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && isValidId(fightId) && isValidFightSchedule(incoming());
      allow update: if isSignedIn() && isValidFightSchedule(incoming());
    }

    match /chatRooms/{roomId} {
      allow get: if isParticipant(resource.data.participantIds);
      allow list: if isSignedIn() && (request.auth.uid in resource.data.participantIds);
      
      allow create: if isParticipant(incoming().participantIds) && isValidChatRoom(incoming());
      
      allow update: if isParticipant(existing().participantIds) && 
                    isParticipant(incoming().participantIds) &&
                    isValidChatRoom(incoming());

      match /messages/{messageId} {
        allow get, list: if isParticipant(get(/databases/$(database)/documents/chatRooms/$(roomId)).data.participantIds);
        allow create: if isParticipant(get(/databases/$(database)/documents/chatRooms/$(roomId)).data.participantIds) &&
                      isValidChatMessage(incoming());
      }
    }
  }
}
